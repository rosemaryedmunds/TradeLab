# Copy this file to .env and fill in real values. .env is gitignored.

# Port the Express server listens on (default 4173)
PORT=4173

# Path to the SQLite DB file. Default: ./data/tradelab.db (relative to project root)
# TRADELAB_DB=/absolute/path/to/tradelab.db

# Massive.com API key for SPX candle data (used by the per-trade chart endpoint).
# Polygon.io keys also work — same API surface.
# Without a key, the chart page will show trade markers with no underlying candles.
MASSIVE_API_KEY=
